<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Social Media</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
    crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="/profile.css">
    <link rel="stylesheet" href="/slide_bar.css">
 
<style>
        /* Base table styling */
        table {
            width: 100%;
            border-collapse: collapse;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        th, td {
            padding: 12px 15px;
            border: 1px solid #ddd;
            text-align: left;
        }
       
        tbody tr {
            transition: background-color 0.2s ease-in-out;
        }
        tbody tr:hover {
            background-color: #f5f5f5;
        }
        
        /* CSS for Stress Level Row Colors */
        .stress-low {
            background-color: #d4edda; /* Green */
        }
        .stress-medium {
            background-color: #fff3cd; /* Yellow */
        }
        .stress-high {
            background-color: #f8d7da; /* Red */
        }
    </style>
</head>

<body>
  <%- include('../partials/Student_sidebar', { currentPage: 'Stress-Data' }) %>
    <div class="main-content">
 <h1>Student Survey Entries</h1>

<% if (entries && entries.length > 0) { %>
    <table>
        <thead>
            <tr>
               <th>Date Submitted</th>
                <th>Sleep Hours</th>
                <th>Study Hours</th>
                <th>Exercise Days</th>
                <th>Social Media Hours</th>
               
                <th>Stress Level</th> </tr>
        </thead>
        <tbody>
            <% entries.forEach(entry => { %>
                <%#
                  This block of EJS code runs on the server to figure out the class name.
                  It checks the stressLevel and assigns 'stress-low', 'stress-medium', or 'stress-high'.
                %>
                <%
                  let rowClass = '';
                  const stress = entry.stressLevel ? entry.stressLevel.toLowerCase() : '';

                  if (stress === 'low') {
                    rowClass = 'stress-low';
                  } else if (stress === 'medium') {
                    rowClass = 'stress-medium';
                  } else if (stress === 'high') {
                    rowClass = 'stress-high';
                  }
                %>

                <%# The class is then added to the table row here %>
                <tr class="<%= rowClass %>">
                   <td><%= entry.createdAt.toDateString() %></td>
                    <td><%= entry.sleepHours %></td>
                    <td><%= entry.studyHours %></td>
                    <td><%= entry.exerciseDays %></td>
                    <td><%= entry.socialMediaHours %></td>
                   
                    <td><%= entry.stressLevel %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>
<% } else { %>
    <p>No entries found.</p>
<% } %>
    </div>

</body>

</html>