<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wellness Survey</title>
    <style>
        /* Your Provided CSS */
        :root {
            --bg-color: #f5f5f5;
            --card-color: #ffffff;
            --text-color: #1a1a1a;
            --accent-color: #a378e9;
            --accent-hover: #cdb1f4;
            --input-bg: #eeeeee;
            --border-color: #cccccc;
            --glow: 0 0 12px rgba(163, 120, 233, 0.4);
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            padding: 20px;
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .main-content {
            width: 100%;
            max-width: 700px;
            background-color: var(--card-color);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 30px 40px;
            box-shadow: var(--glow);
            display: flex;
            flex-direction: column;
            gap: 25px;
        }
        
        /* Form Styles */
        .form-header {
            text-align: center;
            color: var(--text-color);
            font-size: 1.8rem;
            font-weight: 600;
            margin-bottom: 10px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--accent-color);
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 12px; /* Increased gap for better spacing */
        }

        .form-group > label { /* Target the main question label */
            font-weight: 500;
            font-size: 1rem;
            color: #333;
        }

        /* NEW STYLES for Radio Button Options */
        .radio-group {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 10px;
        }
        #displayNone{
            display: none;
        }
        .radio-option {
            display: flex;
            align-items: center;
            background-color: var(--input-bg);
            padding: 10px 15px;
            border-radius: 8px;
            border: 1px solid var(--border-color);
            cursor: pointer;
            transition: all 0.2s ease-in-out;
        }

        .radio-option:hover {
            border-color: var(--accent-color);
            background-color: #f0ebf9;
        }

        .radio-option input[type="radio"] {
            margin-right: 10px;
            /* Modern way to color radio buttons */
            accent-color: var(--accent-color);
            width: 1.1em;
            height: 1.1em;
        }

        .radio-option label {
            font-weight: 400;
            font-size: 0.95rem;
            color: var(--text-color);
            cursor: pointer;
        }
        /* --- End of New Styles --- */

        .submit-btn {
            background-color: var(--accent-color);
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 8px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.3s ease;
            margin-top: 20px;
        }

        .submit-btn:hover {
            background-color: var(--accent-hover);
            color: var(--text-color);
        }
    </style>
</head>

<body>
    
    <div class="main-content">
        <h2 class="form-header">Wellness Survey 📝</h2>
        <form id="wellnessForm" action="/stress-predictor" method="POST">

            <div class="form-group">
                <label>On average, how many hours do you sleep per night?</label>
                <div class="radio-group">
                    <div class="radio-option">
                        <input type="radio" id="sleep1" name="sleepHours" value="Less than 6 hours" required>
                        <label for="sleep1">Less than 6 hours</label>
                    </div>
                    <div class="radio-option">
                        <input type="radio" id="sleep2" name="sleepHours" value="6-8 hours">
                        <label for="sleep2">6-8 hours</label>
                    </div>  
                    <div class="radio-option">
                        <input type="radio" id="sleep4" name="sleepHours" value="More than 8 hours">
                        <label for="sleep4">More than 8 hours</label>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label>On average, how many hours do you study per week?</label>
                <div class="radio-group">
                    <div class="radio-option">
                        <input type="radio" id="study1" name="studyHours" value="0-5 hours" required>
                        <label for="study1">0-5 hours</label>
                    </div>
                    <div class="radio-option">
                        <input type="radio" id="study2" name="studyHours" value="6-10 hours">
                        <label for="study2">5-10 hours</label>
                    </div>
                    <div class="radio-option">
                        <input type="radio" id="study3" name="studyHours" value="11-20 hours">
                        <label for="study3">10-15 hours</label>
                    </div>
                    <div class="radio-option">
                        <input type="radio" id="study4" name="studyHours" value="More than 15 hours">
                        <label for="study4">More than 15 hours</label>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label>How many days a week do you engage in physical activity?</label>
                <div class="radio-group">
                    <div class="radio-option">
                        <input type="radio" id="ex1" name="exerciseDays" value="0 days" required>
                        <label for="ex1">0 days</label>
                    </div>
                    <div class="radio-option">
                        <input type="radio" id="ex2" name="exerciseDays" value="1-2 days">
                        <label for="ex2">1-2 days</label>
                    </div>
                    <div class="radio-option">
                        <input type="radio" id="ex3" name="exerciseDays" value="3 - 4 days">
                        <label for="ex3">3 - 4 days</label>
                    </div>
                    <div class="radio-option">
                        <input type="radio" id="ex4" name="exerciseDays" value="5 or more days">
                        <label for="ex4">5 or more days</label>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label>On an average day, how much time do you spend on social media?</label>
                <div class="radio-group">
                    <div class="radio-option">
                        <input type="radio" id="social1" name="socialMediaHours" value="Less than 1 hour" required>
                        <label for="social1">&lt; Less than 1 hour</label>
                    </div>
                    <div class="radio-option">
                        <input type="radio" id="social2" name="socialMediaHours" value="1 - 3 hours">
                        <label for="social2">1 - 3 hours</label>
                    </div>
                    <div class="radio-option">
                        <input type="radio" id="social3" name="socialMediaHours" value="3 - 5 hours">
                        <label for="social3">3 - 5 hours</label>
                    </div>
                 
                </div>
              

            </div>
 <input type="text" name="studentId" value="<%= userId %>" readonly id="displayNone" >
            <button type="submit" class="submit-btn">Submit</button>
        </form>
    </div>
</body>
</html>